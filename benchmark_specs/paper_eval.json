      "provider": "auto",
      "temperature": 0.0,
      "enabled": true,
      "backend_version": "api"
    }
  ],
  "baselines": [
    {
      "name": "PC",
      "enabled": true,
      "scope": "observational",
      "library": "pgmpy",
      "seed": 42,
      "pc_variant": "stable",
      "pc_ci_test": "chi_square",
      "pc_significance_level": 0.01,
      "pc_max_cond_vars": 5
    },
    {
      "name": "GES",
      "enabled": true,
      "scope": "observational",
      "library": "pgmpy",
      "seed": 42,
      "ges_scoring_method": "bic-d",
      "ges_min_improvement": 1e-6
    },
    {
      "name": "ENCO",
      "enabled": true,
      "scope": "interventional",
      "library": "internal",
      "max_inters": -1,
      "seed": 42,
      "checkpoint_dir": "experiments/checkpoints/benchmarks/paper_eval/ENCO"
    }
  ],
  "evaluator": {
    "tau": 0.7,
    "pred_col": "prediction"
  },
  "provenance": {
    "schema_version": "benchmark_spec/v1",
    "parser_version": "query_api.extract_adjacency",
    "evaluator_version": "evaluate.py",
    "tags": ["micad", "paper_eval", "neurips_db"]
  },
  "notes": "Single-manifest paper evaluation superset. Encodes the Sachs main/body cells, Sachs budget controls, and the six-graph names_only appendix requirement. Because prompt cells are global in benchmark_specs, this will run more than the paper's minimum-required non-Sachs slice set; for minimal execution, use the narrower paper_slices plus the six-graph names_only manifest."
