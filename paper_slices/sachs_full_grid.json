  "names_only": {
    "enabled": true,
    "col_order": "original"
  },
  "baselines": [
    {
      "name": "PC",
      "enabled": true,
      "scope": "observational",
      "library": "pgmpy",
      "seed": 42,
      "pc_variant": "stable",
      "pc_ci_test": "chi_square",
      "pc_significance_level": 0.01,
      "pc_max_cond_vars": 5
    },
    {
      "name": "GES",
      "enabled": true,
      "scope": "observational",
      "library": "pgmpy",
      "seed": 42,
      "ges_scoring_method": "bic-d",
      "ges_min_improvement": 1e-6
    },
    {
      "name": "ENCO",
      "enabled": true,
      "scope": "interventional",
      "library": "internal",
      "max_inters": -1,
      "seed": 42,
      "checkpoint_dir": "experiments/checkpoints/paper_slices/sachs_full_grid/enco"
    },
    {
      "name": "CausalLLMPrompt",
      "enabled": true,
      "scope": "all",
      "model": "gpt-5-mini",
      "provider": "auto",
      "temperature": 0.0,
      "num_samples": 1,
      "notes": "Semantic-only names-only one-shot full-DAG baseline for the full Sachs grid."
    },
    {
      "name": "JiralerspongBFS",
      "enabled": true,
      "scope": "observational",
      "model": "gpt-5-mini",
      "provider": "auto",
      "temperature": 0.0,
      "num_samples": 1,
      "notes": "Observational-summary BFS-style querying baseline for the full Sachs grid."
    },
    {
      "name": "TakayamaSCP",
      "enabled": true,
      "scope": "observational",
      "model": "gpt-5-mini",
      "provider": "auto",
      "temperature": 0.0,
      "num_samples": 1,
      "takayama_pattern": 2,
      "takayama_bootstrap_samples": 100,
      "notes": "Observational-only combined-information PC-based Takayama baseline for the full Sachs grid."
    }
  ],
  "notes": "Full Sachs paper grid for gpt-5-mini: summary and matrix, real and anonymized, across (N,M) in {(0,50),(0,200),(1000,0),(5000,0),(1000,50),(5000,50),(1000,200),(5000,200)}, plus names_only and matched baselines."
}
