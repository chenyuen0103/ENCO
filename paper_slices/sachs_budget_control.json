{
  "name": "sachs_budget_control",
  "role": "control",
  "dataset": "sachs",
  "bif_file": "causal_graphs/real_data/small_graphs/sachs.bif",
  "model": "gpt-5-mini",
  "seed": 42,
  "num_prompts": 5,
  "temperature": 0.0,
  "shuffles_per_graph": 1,
  "prompt_cells": [
    {
      "style": "summary",
      "obs_per_prompt": 1000,
      "int_per_combo": 200,
      "anonymize": false,
      "row_order": "random",
      "col_order": "original",
      "causal_rules": false,
      "give_steps": false,
      "def_int": false,
      "intervene_vars": "all"
    }
  ],
  "enco": {
    "enabled": true,
    "sample_size_obs": 1000,
    "sample_size_inters": 200,
    "max_inters": -1,
    "seed": 42,
    "checkpoint_dir": "experiments/checkpoints/paper_slices/sachs_budget_control/enco"
  },
  "notes": "Supporting control slice for the budget bump on Sachs."
}
